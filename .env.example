# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
BRIGHTDATA_API_KEY=brd-customer-hl_xxxxx-zone-web:xxxxxxxxxxxx
AIMLAPI_KEY=your_aimlapi_key_here

# ---------------------------------------------------------------------------
# AI/ML API — uses OpenAI compatible endpoint
# ---------------------------------------------------------------------------
OPENAI_BASE_URL=https://api.aimlapi.com/v1
OPENAI_API_KEY=${AIMLAPI_KEY}

# ---------------------------------------------------------------------------
# Optional: direct provider API keys (fallback if AI/ML API is down)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ---------------------------------------------------------------------------
# Optional: Cognee MCP (Docker). URL is set in docker-compose, not here
# ---------------------------------------------------------------------------
# COGNEE_MCP_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional: Speechmatics (voice input). Feature degrades gracefully if unset
# ---------------------------------------------------------------------------
# SPEECHMATICS_API_KEY=xxxxxxxx

# ---------------------------------------------------------------------------
# Optional: TriggerWare (workflow automation). Feature degrades gracefully if unset
# ---------------------------------------------------------------------------
# TRIGGERWARE_KEY=xxxxxxxx
