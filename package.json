{
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "lefthook": "^2.1.8",
    "portless": "^0.13.1",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "ultracite": "7.8.0"
  },
  "name": "argus",
  "scripts": {
    "start": "turbo dev",
    "dev": "turbo dev",
    "dev:full": "docker-compose up cognee-mcp -d && turbo dev",
    "cognee": "docker-compose up cognee-mcp -d",
    "cognee:stop": "docker-compose stop cognee-mcp",
    "cognee:logs": "docker-compose logs -f cognee-mcp",
    "dev:backend": "cd apps/backend && portless run bun --watch src/server.ts",
    "dev:frontend": "cd apps/frontend && portless run next dev",
    "build": "turbo build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "lint": "bun run check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "replay": "curl -X POST http://localhost:3001/api/replay -H 'Content-Type: application/json' -d '{\"scenario\":\"nvidia_convergence\"}'",
    "trigger": "curl -X POST http://localhost:3001/api/run -H 'Content-Type: application/json' -d '{\"company\":\"NVIDIA\",\"mode\":\"live\"}'"
  },
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "hash-wasm": "^4.12.0",
    "jose": "^6.2.3"
  }
}
